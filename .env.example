# Copy this file to .env and fill in your own values.
# .env is git-ignored; .env.example is committed as a reference.

# FRED (Federal Reserve Economic Data) API key
# Required by feature 002-data-ingestion to fetch DTB3 (3-month T-bill rate).
# Free registration: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_32_char_hex_key_here
